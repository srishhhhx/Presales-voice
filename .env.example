# -- LiveKit (Cloud mode used -- credentials in .env)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# LOCAL MODE alternative (no cloud account needed):
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# -- Deepgram STT
DEEPGRAM_API_KEY=your_deepgram_api_key

# -- Groq LLM (llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_api_key

# -- AWS Polly TTS (primary TTS -- livekit-plugins-aws)
# Voices used: Raveena (Indian English), Aditi (Hindi)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=ap-south-1

# -- ElevenLabs (post-testing upgrade -- not used during development)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# -- App Settings
LOG_DIR=./logs
SCENARIO=presale
